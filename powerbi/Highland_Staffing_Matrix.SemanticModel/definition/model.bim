        "measures": [
          {
            "name": "Total Census",
            "expression": "SUM(StaffingData[TotalCensus])",
            "lineageTag": "msr-000",
            "formatString": "#,0",
            "displayFolder": "Core Metrics"
          },
          {
            "name": "Occupancy %",
            "expression": "DIVIDE(SUM(StaffingData[TotalCensus]), SUM(StaffingData[TotalStaffedBeds]), 0) * 100",
