          },
          {
            "name": "MTD Avg Daily Census",
            "expression": "VAR _today = TODAY()\nVAR _monthStart = DATE(YEAR(_today), MONTH(_today), 1)\nRETURN\n    CALCULATE(\n        AVERAGE(StaffingData[TotalCensus]),\n        FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _today)\n    )",
            "lineageTag": "msr-031",
            "formatString": "0.0",
            "displayFolder": "MTD Metrics"
          },
          {
            "name": "MTD Avg Census 1East",
