{
  "compatibilityLevel": 1567,
  "model": {
    "culture": "en-US",
    "dataAccessOptions": {
      "legacyRedirects": true,
      "returnErrorValuesAsNull": true
    },
    "defaultPowerBIDataSourceVersion": "powerBI_V3",
    "sourceQueryCulture": "en-US",
    "annotations": [
      {
        "name": "PBI_QueryOrder",
        "value": "[\"SharePointSiteURL\",\"StaffingData\",\"Units\"]"
      }
    ],
    "expressions": [
      {
        "name": "SharePointSiteURL",
        "kind": "m",
        "expression": "let\n    Source = \"https://YOUR_TENANT.sharepoint.com/sites/YOUR_SITE\" meta [IsParameterQuery=true, Type=\"Text\", IsParameterQueryRequired=true]\nin\n    Source",
        "lineageTag": "param-sp-url"
      }
    ],
    "relationships": [
      {
        "name": "DateToStaffing",
        "fromTable": "StaffingData",
        "fromColumn": "DateKey",
        "toTable": "DateTable",
        "toColumn": "Date",
        "crossFilteringBehavior": "bothDirections"
      }
    ],
    "tables": [
      {
        "name": "DateTable",
        "lineageTag": "tbl-date",
        "dataCategory": "Time",
        "isHidden": false,
        "partitions": [
          {
            "name": "DateTable-Partition",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "CALENDAR(DATE(2025,1,1), DATE(2027,12,31))"
            }
          }
        ],
        "columns": [
          {
            "name": "Date",
            "dataType": "dateTime",
            "sourceColumn": "[Date]",
            "isKey": true,
            "lineageTag": "col-dt-date",
            "summarizeBy": "none",
            "type": "calculatedTableColumn",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "formatString": "Short Date"
          },
          {
            "name": "Year",
            "dataType": "int64",
            "lineageTag": "col-dt-year",
            "summarizeBy": "none",
            "type": "calculatedTableColumn",
            "isNameInferred": false,
            "expression": "YEAR([Date])"
          },
          {
            "name": "MonthNum",
            "dataType": "int64",
            "lineageTag": "col-dt-mnum",
            "summarizeBy": "none",
            "type": "calculatedTableColumn",
            "isNameInferred": false,
            "expression": "MONTH([Date])"
          },
          {
            "name": "MonthName",
            "dataType": "string",
            "lineageTag": "col-dt-mname",
            "summarizeBy": "none",
            "type": "calculatedTableColumn",
            "isNameInferred": false,
            "expression": "FORMAT([Date], \"MMMM\")",
            "sortByColumn": "MonthNum"
          },
          {
            "name": "Day",
            "dataType": "int64",
            "lineageTag": "col-dt-day",
            "summarizeBy": "none",
            "type": "calculatedTableColumn",
            "isNameInferred": false,
            "expression": "DAY([Date])"
          },
          {
            "name": "Quarter",
            "dataType": "string",
            "lineageTag": "col-dt-qtr",
            "summarizeBy": "none",
            "type": "calculatedTableColumn",
            "isNameInferred": false,
            "expression": "\"Q\" & FORMAT(QUARTER([Date]), \"0\")"
          },
          {
            "name": "YearMonth",
            "dataType": "string",
            "lineageTag": "col-dt-ym",
            "summarizeBy": "none",
            "type": "calculatedTableColumn",
            "isNameInferred": false,
            "expression": "FORMAT([Date], \"YYYY-MM\")"
          },
          {
            "name": "DayOfWeek",
            "dataType": "string",
            "lineageTag": "col-dt-dow",
            "summarizeBy": "none",
            "type": "calculatedTableColumn",
            "isNameInferred": false,
            "expression": "FORMAT([Date], \"dddd\")"
          }
        ]
      },
      {
        "name": "Units",
        "lineageTag": "tbl-units",
        "partitions": [
          {
            "name": "Units-Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = #table(\n        type table [UnitKey = text, UnitLabel = text, UnitType = text, MaxBeds = number, PayrollBU = text],\n        {\n            {\"1East\", \"1 East - Child Acute\", \"acute\", 18, \"Acute Adult-100E\"},\n            {\"2East\", \"2 East - Adult Acute\", \"acute\", 20, \"Acute Child-200E\"},\n            {\"2West\", \"2 West - Adolescent\", \"acute\", 20, \"Acute Adol-200W\"},\n            {\"3East\", \"3 East - Adult Acute\", \"acute\", 20, \"Acute Adult-300E\"},\n            {\"3West\", \"3 West - Adult Acute\", \"acute\", 20, \"Acute Adult-300W\"},\n            {\"HRC\", \"HRC - SUD/Detox ASAM 3.7\", \"detox\", 16, \"Acute Adult-100\"}\n        }\n    )\nin\n    Source"
            }
          }
        ],
        "columns": [
          {
            "name": "UnitKey",
            "dataType": "string",
            "sourceColumn": "UnitKey",
            "lineageTag": "col-u-key",
            "summarizeBy": "none"
          },
          {
            "name": "UnitLabel",
            "dataType": "string",
            "sourceColumn": "UnitLabel",
            "lineageTag": "col-u-label",
            "summarizeBy": "none"
          },
          {
            "name": "UnitType",
            "dataType": "string",
            "sourceColumn": "UnitType",
            "lineageTag": "col-u-type",
            "summarizeBy": "none"
          },
          {
            "name": "MaxBeds",
            "dataType": "int64",
            "sourceColumn": "MaxBeds",
            "lineageTag": "col-u-beds",
            "summarizeBy": "sum"
          },
          {
            "name": "PayrollBU",
            "dataType": "string",
            "sourceColumn": "PayrollBU",
            "lineageTag": "col-u-bu",
            "summarizeBy": "none"
          }
        ]
      },
      {
        "name": "StaffingData",
        "lineageTag": "tbl-staffing",
        "partitions": [
          {
            "name": "StaffingData-Partition",
