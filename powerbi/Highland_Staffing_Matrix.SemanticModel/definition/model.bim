            "source": {
              "type": "m",
              "expression": "let\n    Source = SharePoint.Tables(SharePointSiteURL, [Implementation=\"2.0\", ApiVersion=15]),\n    StaffingMatrix = Source{[Title=\"StaffingMatrix\"]}[Items],\n    #\"Selected Columns\" = Table.SelectColumns(StaffingMatrix, {\"Timestamp\", \"Date\", \"TimeEntryDate\", \"TotalStaffedBeds\", \"TotalCensus\", \"OccupancyPct\", \"Census_1East\", \"OccPct_1East\", \"Census_2East\", \"OccPct_2East\", \"Census_2West\", \"OccPct_2West\", \"Census_3East\", \"OccPct_3East\", \"Census_3West\", \"OccPct_3West\", \"Census_HRC\", \"OccPct_HRC\", \"ObsHrs_Total\", \"ObsHrs_1East\", \"ObsHrs_2East\", \"ObsHrs_2West\", \"ObsHrs_3East\", \"ObsHrs_3West\", \"ObsHrs_HRC\", \"NP_ModelPct\", \"NP_Multiplier\", \"NP_1East\", \"NP_2East\", \"NP_2West\", \"NP_3East\", \"NP_3West\", \"NP_HRC\", \"1East_Day_RN\", \"1East_Day_LPN\", \"1East_Day_Tech\", \"1East_Evening_RN\", \"1East_Evening_LPN\", \"1East_Evening_Tech\", \"1East_Night_RN\", \"1East_Night_LPN\", \"1East_Night_Tech\", \"1East_ShiftTotal\", \"1East_Ratio_Day\", \"1East_Ratio_Eve\", \"1East_Ratio_Night\", \"2East_Day_RN\", \"2East_Day_LPN\", \"2East_Day_Tech\", \"2East_Evening_RN\", \"2East_Evening_LPN\", \"2East_Evening_Tech\", \"2East_Night_RN\", \"2East_Night_LPN\", \"2East_Night_Tech\", \"2East_ShiftTotal\", \"2East_Ratio_Day\", \"2East_Ratio_Eve\", \"2East_Ratio_Night\", \"2West_Day_RN\", \"2West_Day_LPN\", \"2West_Day_Tech\", \"2West_Evening_RN\", \"2West_Evening_LPN\", \"2West_Evening_Tech\", \"2West_Night_RN\", \"2West_Night_LPN\", \"2West_Night_Tech\", \"2West_ShiftTotal\", \"2West_Ratio_Day\", \"2West_Ratio_Eve\", \"2West_Ratio_Night\", \"3East_Day_RN\", \"3East_Day_LPN\", \"3East_Day_Tech\", \"3East_Evening_RN\", \"3East_Evening_LPN\", \"3East_Evening_Tech\", \"3East_Night_RN\", \"3East_Night_LPN\", \"3East_Night_Tech\", \"3East_ShiftTotal\", \"3East_Ratio_Day\", \"3East_Ratio_Eve\", \"3East_Ratio_Night\", \"3West_Day_RN\", \"3West_Day_LPN\", \"3West_Day_Tech\", \"3West_Evening_RN\", \"3West_Evening_LPN\", \"3West_Evening_Tech\", \"3West_Night_RN\", \"3West_Night_LPN\", \"3West_Night_Tech\", \"3West_ShiftTotal\", \"3West_Ratio_Day\", \"3West_Ratio_Eve\", \"3West_Ratio_Night\", \"HRC_Day_RN\", \"HRC_Day_LPN\", \"HRC_Day_Tech\", \"HRC_Evening_RN\", \"HRC_Evening_LPN\", \"HRC_Evening_Tech\", \"HRC_Night_RN\", \"HRC_Night_LPN\", \"HRC_Night_Tech\", \"HRC_ShiftTotal\", \"HRC_Ratio_Day\", \"HRC_Ratio_Eve\", \"HRC_Ratio_Night\", \"Total_RN\", \"Total_LPN\", \"Total_Tech\", \"Total_ShiftStaff\", \"StaffPerShift\", \"FloatShiftPositions\", \"RN_ProdFTE\", \"RN_AdjFTE\", \"LPN_ProdFTE\", \"LPN_AdjFTE\", \"Tech_ProdFTE\", \"Tech_AdjFTE\", \"Float_ProdFTE\", \"Float_AdjFTE\", \"OneOne_ProdFTE\", \"OneOne_AdjFTE\", \"VarProdFTE\", \"VarAdjFTE\", \"VarNP_Add\", \"FixedFTE\", \"FixedHC\", \"FixedSource\", \"GrandProdFTE\", \"GrandAdjFTE\", \"EPOB_DirectCare\", \"EPOB_TotalFacility\", \"EPOB_Productive\", \"EPOB_VarPerPatient\", \"EPOB_FixPerPatient\", \"HasPayrollData\", \"PayrollFileName\", \"PayrollDayCount\", \"PayrollStartDate\", \"PayrollEndDate\", \"Actual_HrsDay_1East\", \"Actual_HC_1East\", \"Actual_OT_1East\", \"Actual_NpHrs_1East\", \"Actual_Wages_1East\", \"Model_HrsDay_1East\", \"Variance_HrsDay_1East\", \"Variance_Pct_1East\", \"Actual_HrsDay_2East\", \"Actual_HC_2East\", \"Actual_OT_2East\", \"Actual_NpHrs_2East\", \"Actual_Wages_2East\", \"Model_HrsDay_2East\", \"Variance_HrsDay_2East\", \"Variance_Pct_2East\", \"Actual_HrsDay_2West\", \"Actual_HC_2West\", \"Actual_OT_2West\", \"Actual_NpHrs_2West\", \"Actual_Wages_2West\", \"Model_HrsDay_2West\", \"Variance_HrsDay_2West\", \"Variance_Pct_2West\", \"Actual_HrsDay_3East\", \"Actual_HC_3East\", \"Actual_OT_3East\", \"Actual_NpHrs_3East\", \"Actual_Wages_3East\", \"Model_HrsDay_3East\", \"Variance_HrsDay_3East\", \"Variance_Pct_3East\", \"Actual_HrsDay_3West\", \"Actual_HC_3West\", \"Actual_OT_3West\", \"Actual_NpHrs_3West\", \"Actual_Wages_3West\", \"Model_HrsDay_3West\", \"Variance_HrsDay_3West\", \"Variance_Pct_3West\", \"Actual_HrsDay_HRC\", \"Actual_HC_HRC\", \"Actual_OT_HRC\", \"Actual_NpHrs_HRC\", \"Actual_Wages_HRC\", \"Model_HrsDay_HRC\", \"Variance_HrsDay_HRC\", \"Variance_Pct_HRC\", \"Actual_VarHrsDay_Total\", \"Actual_FixHrsDay_Total\", \"Actual_VarHC_Total\", \"Actual_FixHC_Total\", \"Actual_OT_Total\", \"Model_VarHrsDay_Total\", \"Variance_VarHrsDay_Total\", \"Variance_VarPct_Total\", \"Actual_VarFTE\", \"Actual_FixFTE\", \"Actual_TotalFTE\", \"Actual_EPOB_DC\", \"Actual_EPOB_Total\", \"EPOB_DC_Variance\", \"EPOB_Total_Variance\"}),\n    #\"Added DateKey\" = Table.AddColumn(#\"Selected Columns\", \"DateKey\", each Date.From(Text.Trim([Date])), type date)\nin\n    #\"Added DateKey\""
