          {
            "name": "Prior Month Avg Census",
            "expression": "VAR _today = TODAY()\nVAR _priorMonthEnd = DATE(YEAR(_today), MONTH(_today), 1) - 1\nVAR _priorMonthStart = DATE(YEAR(_priorMonthEnd), MONTH(_priorMonthEnd), 1)\nRETURN\n    CALCULATE(\n        AVERAGE(StaffingData[TotalCensus]),\n        FILTER(ALL(DateTable), DateTable[Date] >= _priorMonthStart && DateTable[Date] <= _priorMonthEnd)\n    )",
            "lineageTag": "msr-061",
            "formatString": "0.0",
