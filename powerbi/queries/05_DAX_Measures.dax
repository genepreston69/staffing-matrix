// ────────────────────────────────────────────────────────────
// FOLDER: Comparisons
// ────────────────────────────────────────────────────────────

Prior Month Avg Census =
VAR _today = TODAY()
VAR _priorMonthEnd = DATE(YEAR(_today), MONTH(_today), 1) - 1
VAR _priorMonthStart = DATE(YEAR(_priorMonthEnd), MONTH(_priorMonthEnd), 1)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[TotalCensus]),
        FILTER(ALL(DateTable), DateTable[Date] >= _priorMonthStart && DateTable[Date] <= _priorMonthEnd)
    )
// Format: 0.0

Census MTD vs Prior Month = [MTD Avg Daily Census] - [Prior Month Avg Census]
// Format: +0.0;-0.0;0.0

Census MTD vs Prior Month % = DIVIDE([MTD Avg Daily Census] - [Prior Month Avg Census], [Prior Month Avg Census], 0) * 100
// Format: +0.0;-0.0;0.0

Actual vs Model FTE Variance = SUM(StaffingData[Actual_TotalFTE]) - SUM(StaffingData[GrandAdjFTE])
// Format: +0.0;-0.0;0.0
