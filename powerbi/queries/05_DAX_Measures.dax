VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(AVERAGE(StaffingData[Census_2West]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD Avg Census 3East =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(AVERAGE(StaffingData[Census_3East]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD Avg Census 3West =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(AVERAGE(StaffingData[Census_3West]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD Avg Census HRC =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(AVERAGE(StaffingData[Census_HRC]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit


// ── MTD: By Unit (Occupancy %) ───────────────────────────────────────────

MTD Avg Occ% 1East = DIVIDE([MTD Avg Census 1East], 18, 0) * 100
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD Avg Occ% 2East = DIVIDE([MTD Avg Census 2East], 20, 0) * 100
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD Avg Occ% 2West = DIVIDE([MTD Avg Census 2West], 20, 0) * 100
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD Avg Occ% 3East = DIVIDE([MTD Avg Census 3East], 20, 0) * 100
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD Avg Occ% 3West = DIVIDE([MTD Avg Census 3West], 20, 0) * 100
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD Avg Occ% HRC = DIVIDE([MTD Avg Census HRC], 16, 0) * 100
// Format: 0.0  |  Display Folder: MTD - By Unit


// ── MTD: By Unit (OT Hours) ─────────────────────────────────────────────

MTD OT 1East =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(SUM(StaffingData[Actual_OT_1East]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD OT 2East =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(SUM(StaffingData[Actual_OT_2East]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD OT 2West =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(SUM(StaffingData[Actual_OT_2West]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD OT 3East =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(SUM(StaffingData[Actual_OT_3East]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD OT 3West =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(SUM(StaffingData[Actual_OT_3West]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit

MTD OT HRC =
VAR _monthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _monthEnd = EOMONTH(_monthStart, 0)
RETURN
    CALCULATE(SUM(StaffingData[Actual_OT_HRC]), FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _monthEnd))
// Format: 0.0  |  Display Folder: MTD - By Unit


// ── MTD: Prior Month Comparison ──────────────────────────────────────────

Prior Month Avg Census =
VAR _curMonthStart = DATE(YEAR(MIN(DateTable[Date])), MONTH(MIN(DateTable[Date])), 1)
VAR _priorMonthStart = EDATE(_curMonthStart, -1)
VAR _priorMonthEnd = _curMonthStart - 1
RETURN
    CALCULATE(
        AVERAGE(StaffingData[TotalCensus]),
        FILTER(ALL(DateTable), DateTable[Date] >= _priorMonthStart && DateTable[Date] <= _priorMonthEnd)
    )
// Format: 0.0  |  Display Folder: MTD - Comparisons

MTD vs Prior Month Census = [MTD Avg Daily Census] - [Prior Month Avg Census]
// Format: +0.0;-0.0;0.0  |  Display Folder: MTD - Comparisons

MTD vs Prior Month % = DIVIDE([MTD Avg Daily Census] - [Prior Month Avg Census], [Prior Month Avg Census], 0) * 100
// Format: +0.0;-0.0;0.0  |  Display Folder: MTD - Comparisons


// ════════════════════════════════════════════════════════════════════════════
//  YTD DASHBOARD MEASURES
//  (Averages & totals from Jan 1 of selected year through last data point)
//  These respond to the date slicer — select any date in the target year
// ════════════════════════════════════════════════════════════════════════════

// ── YTD: Facility Total ──────────────────────────────────────────────────

YTD Avg Daily Census =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[TotalCensus]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: 0.0  |  Display Folder: YTD - Facility

YTD Avg Occupancy % = DIVIDE([YTD Avg Daily Census], 114, 0) * 100
// Format: 0.0  |  Display Folder: YTD - Facility

YTD Avg DC EPOB =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[EPOB_DirectCare]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: 0.00  |  Display Folder: YTD - Facility

YTD Avg Total EPOB =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[EPOB_TotalFacility]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: 0.00  |  Display Folder: YTD - Facility

YTD Avg Variable FTE =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[VarAdjFTE]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: 0.0  |  Display Folder: YTD - Facility

YTD Avg Fixed FTE =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[FixedFTE]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: 0.0  |  Display Folder: YTD - Facility

YTD Avg Grand FTE =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[GrandAdjFTE]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: 0.0  |  Display Folder: YTD - Facility

YTD Avg Total Staff =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[Total_ShiftStaff]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: 0.0  |  Display Folder: YTD - Facility

YTD Total OT Hours =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        SUM(StaffingData[Actual_OT_Total]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: 0.0  |  Display Folder: YTD - Facility

YTD Avg Hours Variance =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[Variance_VarHrsDay_Total]),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: +0.0;-0.0;0.0  |  Display Folder: YTD - Facility

YTD Days Count =
VAR _yearStart = DATE(YEAR(MIN(DateTable[Date])), 1, 1)
VAR _yearEnd = DATE(YEAR(MIN(DateTable[Date])), 12, 31)
RETURN
    CALCULATE(
        COUNTROWS(StaffingData),
        FILTER(ALL(DateTable), DateTable[Date] >= _yearStart && DateTable[Date] <= _yearEnd)
    )
// Format: #,0  |  Display Folder: YTD - Facility


