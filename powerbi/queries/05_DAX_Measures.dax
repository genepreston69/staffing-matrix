MTD Avg Hours Variance =
VAR _today = TODAY()
VAR _monthStart = DATE(YEAR(_today), MONTH(_today), 1)
RETURN
    CALCULATE(
        AVERAGE(StaffingData[Variance_VarHrsDay_Total]),
        FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _today)
    )
// Format: 0.0

MTD Days Count =
VAR _today = TODAY()
VAR _monthStart = DATE(YEAR(_today), MONTH(_today), 1)
RETURN
    CALCULATE(
        COUNTROWS(StaffingData),
        FILTER(ALL(DateTable), DateTable[Date] >= _monthStart && DateTable[Date] <= _today)
    )
// Format: #,0


