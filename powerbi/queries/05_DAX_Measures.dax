// ── YTD: By Unit (Occupancy %) ───────────────────────────────────────────

YTD Avg Occ% 1East = DIVIDE([YTD Avg Census 1East], 18, 0) * 100
// Format: 0.0  |  Display Folder: YTD - By Unit

YTD Avg Occ% 2East = DIVIDE([YTD Avg Census 2East], 20, 0) * 100
// Format: 0.0  |  Display Folder: YTD - By Unit

YTD Avg Occ% 2West = DIVIDE([YTD Avg Census 2West], 20, 0) * 100
// Format: 0.0  |  Display Folder: YTD - By Unit

YTD Avg Occ% 3East = DIVIDE([YTD Avg Census 3East], 20, 0) * 100
// Format: 0.0  |  Display Folder: YTD - By Unit

YTD Avg Occ% 3West = DIVIDE([YTD Avg Census 3West], 20, 0) * 100
// Format: 0.0  |  Display Folder: YTD - By Unit

YTD Avg Occ% HRC = DIVIDE([YTD Avg Census HRC], 16, 0) * 100
// Format: 0.0  |  Display Folder: YTD - By Unit


